---
import '@/styles/global.css'

import Header from '@/components/Header.astro'
import Footer from '@/components/Footer.astro'

const defaultTitle = 'Chicharronería Don Emiliano'
const defaultDescription =
  'Los mejores chicharrones de Lima. Crujientes por fuera, jugosos por dentro. Pide delivery o recoge en tienda.'

export interface Props {
  title?: string
  description?: string
  hideHeader?: boolean
  hideFooter?: boolean
}

let { title, description, hideHeader = false, hideFooter = false } = Astro.props

title ??= defaultTitle
description ??= defaultDescription
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <title>{title}</title>

    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#ff5d00" />

    <!-- Preconnect to Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
  </head>
  <body class="font-sans antialiased text-ink bg-surface">
    <div class="min-h-screen flex flex-col">
      {!hideHeader && <Header />}
      <div class="flex-1">
        <slot />
      </div>
      {!hideFooter && <Footer />}
    </div>
  </body>
</html>

<style>
  html {
    scroll-behavior: smooth;
  }

  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
  }

  body {
    font-family:
      'Inter',
      system-ui,
      -apple-system,
      sans-serif;
  }
</style>
