---
import OrderCartList from './order/OrderCartList.tsx'
import TrashIcon from '@/components/icons/Trash.astro'
import Order from './order/Order.tsx'
---

<section class="w-full">
  <div class="grid grid-cols-1 gap-6 lg:grid-cols-[1fr_420px]">
    <!-- Products grid -->
    <div class="pt-2">
      <Order client:load />
    </div>

    <!-- Desktop cart sidebar -->
    <div class="hidden lg:block">
      <div class="sticky top-28 rounded-xl border border-gray-100 bg-white shadow-lg overflow-hidden">
        <!-- Cart header -->
        <div class="px-5 py-4 bg-gradient-to-r from-primary/5 to-transparent border-b border-gray-100">
          <div class="flex items-center justify-between">
            <h3 class="text-lg font-bold text-heading flex items-center gap-2">
              <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
              </svg>
              Tu pedido
            </h3>
            <span id="cart-item-count" class="text-xs font-semibold text-ink-muted bg-gray-100 px-2 py-0.5 rounded-full">
              0 items
            </span>
          </div>
        </div>

        <!-- Cart items -->
        <div class="px-4 py-2">
          <OrderCartList client:load />
        </div>

        <!-- Price summary -->
        <div class="px-5 py-3 border-t border-gray-100 bg-gray-50/50">
          <div class="flex items-center justify-between text-sm text-ink-muted mb-1">
            <span>Subtotal</span>
            <span id="order-subtotal-price" class="font-medium text-ink">S/ 0.00</span>
          </div>
          <div class="flex items-center justify-between text-sm text-ink-muted mb-2">
            <span>Delivery</span>
            <span class="font-medium text-ink">S/ 5.00</span>
          </div>
          <div class="h-px bg-gray-200 my-2" aria-hidden="true"></div>
          <div class="flex items-center justify-between">
            <span class="text-lg font-bold text-heading">Total</span>
            <span id="order-total-price" class="text-lg font-bold text-primary">S/ 5.00</span>
          </div>
        </div>

        <!-- Action buttons -->
        <div class="px-5 pb-5 pt-2 space-y-2">
          <button
            id="order-btn"
            class="w-full flex items-center justify-center gap-2 bg-primary text-white py-3 rounded-lg font-semibold cursor-pointer hover:bg-action-hover active:bg-action-pressed transition-all duration-200 shadow-md hover:shadow-lg"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            Realizar mi pedido
          </button>
          <button
            id="empty-cart-btn"
            class="w-full flex items-center justify-center gap-2 py-2.5 rounded-lg font-medium cursor-pointer text-ink-muted border border-gray-200 hover:border-red-200 hover:bg-red-50 hover:text-red-600 transition-all duration-200"
          >
            <TrashIcon className="w-5" />
            Vaciar carrito
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- Mobile floating cart button -->
  <div id="mobile-cart-btn" class="lg:hidden fixed bottom-6 left-4 right-4 z-40 hidden">
    <button
      id="mobile-order-btn"
      class="w-full flex items-center justify-between bg-primary text-white py-3.5 px-5 rounded-2xl font-semibold cursor-pointer shadow-xl shadow-primary/25 hover:bg-action-hover active:bg-action-pressed transition-all duration-200"
    >
      <div class="flex items-center gap-2">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
        </svg>
        <span id="mobile-cart-count">0 productos</span>
      </div>
      <div class="flex items-center gap-2">
        <span>Ver pedido</span>
        <span id="mobile-cart-total" class="bg-white/20 px-2.5 py-0.5 rounded-full text-sm">S/ 0.00</span>
      </div>
    </button>
  </div>
</section>

<script>
  import { cartItems } from '@/stores/order'

  const orderSubtotalPrice = document.getElementById('order-subtotal-price')
  const orderTotalPrice = document.getElementById('order-total-price')
  const cartItemCount = document.getElementById('cart-item-count')
  const mobileCartBtn = document.getElementById('mobile-cart-btn')
  const mobileCartCount = document.getElementById('mobile-cart-count')
  const mobileCartTotal = document.getElementById('mobile-cart-total')

  cartItems.listen(items => {
    const products = Object.values(items)
    const total = products.reduce((acc, product) => acc + product.price * product.quantity, 0)
    const itemCount = products.reduce((acc, product) => acc + product.quantity, 0)

    if (orderSubtotalPrice) {
      orderSubtotalPrice.textContent = `S/ ${total.toFixed(2)}`
    }
    if (orderTotalPrice) {
      orderTotalPrice.textContent = `S/ ${(total + 5).toFixed(2)}`
    }
    if (cartItemCount) {
      cartItemCount.textContent = `${itemCount} item${itemCount !== 1 ? 's' : ''}`
    }

    // Mobile floating cart
    if (mobileCartBtn) {
      if (itemCount > 0) {
        mobileCartBtn.classList.remove('hidden')
      } else {
        mobileCartBtn.classList.add('hidden')
      }
    }
    if (mobileCartCount) {
      mobileCartCount.textContent = `${itemCount} producto${itemCount !== 1 ? 's' : ''}`
    }
    if (mobileCartTotal) {
      mobileCartTotal.textContent = `S/ ${(total + 5).toFixed(2)}`
    }
  })

  const emptyCart = document.getElementById('empty-cart-btn')
  if (emptyCart) {
    emptyCart.addEventListener('click', () => cartItems.set({}))
  }

  const orderBtn = document.getElementById('order-btn')
  if (orderBtn) {
    orderBtn.addEventListener('click', () => (document.location.href = '/completa-tu-orden'))
  }

  const mobileOrderBtn = document.getElementById('mobile-order-btn')
  if (mobileOrderBtn) {
    mobileOrderBtn.addEventListener('click', () => (document.location.href = '/completa-tu-orden'))
  }
</script>
