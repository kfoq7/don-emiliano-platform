---
import MapPicker from './MapPicker.astro'
---

<!-- Location Modal -->
<div
  id="location-modal"
  class="hidden fixed inset-0 z-50 items-center justify-center p-4"
  role="dialog"
  aria-modal="true"
  aria-labelledby="modal-title"
>
  <!-- Backdrop -->
  <div id="modal-backdrop" class="absolute inset-0 bg-black/60 backdrop-blur-sm transition-opacity duration-300 opacity-0"></div>

  <!-- Modal panel -->
  <div id="modal-panel" class="relative bg-white rounded-2xl shadow-2xl max-w-4xl w-full max-h-[90vh] flex flex-col overflow-hidden transition-all duration-300 scale-95 opacity-0">
    <!-- Modal Header -->
    <div class="flex items-center justify-between px-5 py-4 border-b border-gray-100">
      <div class="flex items-center gap-3">
        <div class="w-9 h-9 rounded-lg bg-primary/10 flex items-center justify-center">
          <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
        </div>
        <h3 id="modal-title" class="text-lg font-bold text-heading">Selecciona tu ubicacion</h3>
      </div>
      <button
        type="button"
        id="close-modal-btn"
        class="w-9 h-9 flex items-center justify-center rounded-lg text-ink-muted hover:text-ink hover:bg-surface-hover transition-colors cursor-pointer"
        aria-label="Cerrar"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <!-- Modal Body -->
    <div class="flex-1 overflow-hidden">
      <MapPicker />
    </div>

    <!-- Modal Footer -->
    <div class="px-5 py-4 border-t border-gray-100 bg-gray-50/50 flex justify-end gap-3">
      <button
        type="button"
        id="cancel-location-btn"
        class="px-5 py-2.5 text-ink-muted bg-white border border-gray-200 hover:bg-gray-50 rounded-lg font-medium transition-colors cursor-pointer"
      >
        Cancelar
      </button>
      <button
        type="button"
        id="confirm-location-btn"
        class="px-6 py-2.5 bg-primary hover:bg-action-hover active:bg-action-pressed text-white rounded-lg font-semibold transition-all duration-200 shadow-md hover:shadow-lg cursor-pointer"
      >
        Confirmar ubicacion
      </button>
    </div>
  </div>
</div>

<script>
  const modal = document.getElementById('location-modal') as HTMLDivElement
  const backdrop = document.getElementById('modal-backdrop') as HTMLDivElement
  const panel = document.getElementById('modal-panel') as HTMLDivElement
  const closeModalBtn = document.getElementById('close-modal-btn') as HTMLButtonElement
  const cancelLocationBtn = document.getElementById('cancel-location-btn') as HTMLButtonElement
  const confirmLocationBtn = document.getElementById('confirm-location-btn') as HTMLButtonElement

  // Animate modal close
  const closeModal = () => {
    if (backdrop) {
      backdrop.classList.add('opacity-0')
      backdrop.classList.remove('opacity-100')
    }
    if (panel) {
      panel.classList.add('scale-95', 'opacity-0')
      panel.classList.remove('scale-100', 'opacity-100')
    }
    // Wait for animation then hide
    setTimeout(() => {
      modal?.classList.add('hidden')
      modal?.classList.remove('flex')
      document.body.style.overflow = ''
    }, 200)
  }

  // Animate modal open
  function openModal() {
    if (modal) {
      modal.classList.remove('hidden')
      modal.classList.add('flex')
      document.body.style.overflow = 'hidden'

      // Trigger entrance animation on next frame
      requestAnimationFrame(() => {
        if (backdrop) {
          backdrop.classList.remove('opacity-0')
          backdrop.classList.add('opacity-100')
        }
        if (panel) {
          panel.classList.remove('scale-95', 'opacity-0')
          panel.classList.add('scale-100', 'opacity-100')
        }
      })

      // Dispatch event to initialize map
      const mapContainer = modal.querySelector('.map-picker-container')
      if (mapContainer) {
        mapContainer.dispatchEvent(new CustomEvent('modal-opened'))
      }
    }
  }

  // Attach to window for external access
  if (typeof window !== 'undefined') {
    ;(window as any).openLocationModal = openModal
    ;(window as any).closeLocationModal = closeModal
  }

  // Close modal handlers
  closeModalBtn?.addEventListener('click', closeModal)
  cancelLocationBtn?.addEventListener('click', closeModal)

  // Close on backdrop click
  backdrop?.addEventListener('click', closeModal)

  // Confirm location
  confirmLocationBtn?.addEventListener('click', () => {
    closeModal()
    window.dispatchEvent(new CustomEvent('location-confirmed'))
  })

  // Close on Escape key
  document.addEventListener('keydown', e => {
    if (e.key === 'Escape' && !modal?.classList.contains('hidden')) {
      closeModal()
    }
  })
</script>
