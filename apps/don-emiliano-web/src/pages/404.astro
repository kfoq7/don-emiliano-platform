---
import Layout from '@/layouts/Layout.astro'
---

<Layout title="Página no encontrada - Don Emiliano">
  <section
    class="relative min-h-screen flex flex-col items-center justify-center overflow-hidden"
  >
    <!-- Decorative background -->
    <div
      class="absolute inset-0 bg-linear-to-br from-orange-50 via-white to-green-50/30"
      aria-hidden="true"
    >
    </div>
    <div
      class="absolute top-0 right-0 w-96 h-96 bg-primary/5 rounded-full blur-3xl -translate-y-1/2 translate-x-1/3"
      aria-hidden="true"
    >
    </div>
    <div
      class="absolute bottom-0 left-0 w-80 h-80 bg-surface-mint/50 rounded-full blur-3xl translate-y-1/3 -translate-x-1/4"
      aria-hidden="true"
    >
    </div>

    <div class="relative z-10 flex flex-col items-center px-4 text-center">
      <!-- 404 number -->
      <h1
        class="text-8xl sm:text-9xl font-black text-gradient tracking-tight animate-fade-in select-none"
      >
        404
      </h1>

      <!-- Title -->
      <h2
        class="mt-4 text-2xl sm:text-3xl font-bold text-heading animate-fade-in-up stagger-1"
      >
        Página no encontrada
      </h2>

      <!-- Description -->
      <p
        class="mt-3 text-ink-muted text-sm sm:text-base max-w-md animate-fade-in-up stagger-2"
      >
        Lo sentimos, la página que buscas no existe o fue movida. Pero nuestros
        chicharrones siguen aquí.
      </p>

      <!-- Actions -->
      <div
        class="mt-8 flex flex-col sm:flex-row items-center gap-4 animate-fade-in-up stagger-3"
      >
        <a
          href="/"
          class="group inline-flex items-center gap-2 bg-primary text-white px-8 py-3.5 rounded-full font-bold text-base tracking-wide shadow-lg hover:shadow-xl hover:bg-action-hover active:bg-action-pressed transition-all duration-300 hover:-translate-y-0.5 active:translate-y-0"
        >
          <svg
            class="w-5 h-5 transition-transform duration-300 group-hover:-translate-x-1"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M11 17l-5-5m0 0l5-5m-5 5h12"></path>
          </svg>
          <span>Volver al inicio</span>
        </a>

        <a
          href="/haz-tu-pedido"
          class="inline-flex items-center gap-2 px-8 py-3.5 rounded-full font-bold text-base tracking-wide border border-border text-ink hover:bg-surface-hover active:bg-surface-pressed transition-all duration-300"
        >
          <span>Ver el menú</span>
        </a>
      </div>
    </div>
  </section>
</Layout>
