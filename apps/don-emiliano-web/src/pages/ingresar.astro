---
import '@/styles/global.css'

// Check for phone session (guest mode)
const phoneSession = Astro.cookies.get('guest_phone')?.value

// Check if user is logged in
const user = Astro.locals.user
const isLoggedIn = !!(user || phoneSession)

// Get user display info
const userEmail = user?.email || null
const userPhone = phoneSession || null
const userName = user?.user_metadata?.full_name || user?.user_metadata?.name || null

const error = Astro.url.searchParams.get('error')
const errorMessages: Record<string, string> = {
  invalid_provider: 'Proveedor de autenticacion no valido',
  auth_failed: 'Error al autenticar. Intenta nuevamente.',
  no_code: 'Codigo de verificacion no proporcionado',
  not_registered: 'No estas registrado como cliente.',
  registration_required: 'Completa tu registro para continuar.',
  invalid_name: 'El nombre debe tener al menos 2 caracteres.',
  email_exists: 'Este correo ya esta registrado.',
  registration_failed: 'Error al registrar. Intenta nuevamente.',
}
const errorMessage = error ? errorMessages[error] || 'Ha ocurrido un error' : null

const redirectTo = Astro.url.searchParams.get('redirect') || '/'

// Check if coming from registration requirement
const needsRegistration = Astro.url.searchParams.get('register') === 'true'
const pendingEmail = Astro.url.searchParams.get('email') || ''
const pendingName = Astro.url.searchParams.get('name') || ''
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <title>Ingresar - Don Emiliano</title>
  </head>
  <body class="font-sans antialiased text-ink bg-gray-50 min-h-screen flex flex-col">
    <!-- Header -->
    <header class="bg-white border-b border-gray-100">
      <div class="max-w-md mx-auto px-4 h-14 flex items-center justify-center">
        <a href="/" class="flex items-center gap-2 text-primary font-bold text-lg">
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 20 20">
            <path
              d="M10.707 2.293a1 1 0 00-1.414 0l-7 7a1 1 0 001.414 1.414L4 10.414V17a1 1 0 001 1h2a1 1 0 001-1v-2a1 1 0 011-1h2a1 1 0 011 1v2a1 1 0 001 1h2a1 1 0 001-1v-6.586l.293.293a1 1 0 001.414-1.414l-7-7z"
            ></path>
          </svg>
          Don Emiliano
        </a>
      </div>
    </header>

    <!-- Main Content -->
    <main class="flex-1 flex items-center justify-center p-4">
      <div class="w-full max-w-sm">
        <!-- Login Card -->
        <div class="bg-white rounded-2xl shadow-lg border border-gray-100 p-6 animate-scale-in">
          {isLoggedIn ? (
            <!-- Logged In State -->
            <div class="text-center">
              <div class="mb-6">
                <div class="w-16 h-16 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-4">
                  <svg class="w-8 h-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                  </svg>
                </div>
                <h1 class="text-2xl font-bold text-heading mb-2">Ya estas conectado</h1>
                <p class="text-sm text-ink-muted">
                  {userName ? `Hola, ${userName}` : userEmail ? userEmail : `+51 ${userPhone}`}
                </p>
              </div>

              <div class="space-y-3">
                <a
                  href="/"
                  class="block w-full py-3 px-4 bg-primary text-white font-semibold rounded-xl hover:bg-action-hover active:bg-action-pressed transition-colors text-center"
                >
                  Ir al inicio
                </a>

                <form action="/api/auth/signout" method="POST">
                  <button
                    type="submit"
                    class="w-full py-3 px-4 bg-white border border-gray-200 text-ink font-medium rounded-xl hover:bg-surface-hover active:bg-surface-pressed transition-colors flex items-center justify-center gap-2"
                  >
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
                    </svg>
                    Cerrar sesion
                  </button>
                </form>
              </div>
            </div>
          ) : (
            <!-- Not Logged In State -->
            <Fragment>
              <div class="text-center mb-6">
                <h1 class="text-2xl font-bold text-heading mb-2">
                  {needsRegistration ? 'Completa tu registro' : 'Bienvenido'}
                </h1>
                <p class="text-sm text-ink-muted">
                  {
                    needsRegistration
                      ? 'Ingresa tu nombre para continuar'
                      : 'Ingresa con tu telefono o Google'
                  }
                </p>
              </div>

              {
                errorMessage && (
                  <div class="mb-4 p-3 bg-red-50 border border-red-200 rounded-lg">
                    <p class="text-sm text-red-600 text-center">{errorMessage}</p>
                  </div>
                )
              }

              <!-- Login Container -->
              <div id="login-container">
                <!-- Registration Form (for new Google users) -->
                <form
                  id="registration-form"
                  action="/api/auth/register"
                  method="POST"
                  class={needsRegistration ? 'space-y-4' : 'hidden space-y-4'}
                >
                  <input type="hidden" name="redirect" value={redirectTo} />
                  <input type="hidden" name="email" value={pendingEmail} />

                  <div>
                    <label for="register-name" class="block text-sm font-medium text-ink mb-1.5">
                      Nombre completo
                    </label>
                    <input
                      type="text"
                      id="register-name"
                      name="name"
                      value={pendingName}
                      placeholder="Tu nombre"
                      required
                      minlength="2"
                      class="w-full px-4 py-3 border border-gray-200 rounded-xl text-ink placeholder:text-ink-subtle focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-all"
                    />
                  </div>

                  <button
                    type="submit"
                    class="w-full py-3 px-4 bg-primary text-white font-semibold rounded-xl hover:bg-action-hover active:bg-action-pressed transition-colors flex items-center justify-center gap-2"
                  >
                    Completar registro
                  </button>

                  <button
                    type="button"
                    id="btn-cancel-register"
                    class="w-full py-2 text-sm text-ink-muted hover:text-ink transition-colors"
                  >
                    Cancelar
                  </button>
                </form>

                <!-- Phone Input (Guest Mode) -->
                <div id="phone-section" class={needsRegistration ? 'hidden space-y-4' : 'space-y-4'}>
                  <div>
                    <label for="phone-input" class="block text-sm font-medium text-ink mb-1.5">
                      Numero de telefono
                    </label>
                    <input
                      type="tel"
                      id="phone-input"
                      name="phone"
                      placeholder="987654321"
                      maxlength="9"
                      inputmode="numeric"
                      pattern="9[0-9]{8}"
                      class="w-full px-4 py-3 border border-gray-200 rounded-xl text-ink placeholder:text-ink-subtle focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-all"
                    />
                    <p id="phone-hint" class="mt-1.5 text-xs text-ink-muted hidden">
                      Ingresa un numero peruano de 9 digitos
                </p>
              </div>

              <button
                id="btn-continue-phone"
                type="button"
                disabled
                class="w-full py-3 px-4 bg-primary text-white font-semibold rounded-xl hover:bg-action-hover active:bg-action-pressed transition-colors disabled:bg-action-disabled disabled:cursor-not-allowed flex items-center justify-center gap-2"
              >
                Continuar
              </button>

              <!-- Divider -->
              <div class="relative my-6">
                <div class="absolute inset-0 flex items-center">
                  <div class="w-full border-t border-gray-200"></div>
                </div>
                <div class="relative flex justify-center text-sm">
                  <span class="px-3 bg-white text-ink-muted">o continua con</span>
                </div>
              </div>

              <!-- Google Sign In -->
              <form action="/api/auth/signin" method="POST">
                <input type="hidden" name="provider" value="google" />
                <input type="hidden" name="redirect" value={redirectTo} />
                <button
                  type="submit"
                  class="w-full py-3 px-4 bg-white border border-gray-200 text-ink font-medium rounded-xl hover:bg-surface-hover active:bg-surface-pressed transition-colors flex items-center justify-center gap-3"
                >
                  <svg class="w-5 h-5" viewBox="0 0 24 24">
                    <path
                      fill="#4285F4"
                      d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"
                    ></path>
                    <path
                      fill="#34A853"
                      d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"
                    ></path>
                    <path
                      fill="#FBBC05"
                      d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"
                    ></path>
                    <path
                      fill="#EA4335"
                      d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"
                    ></path>
                  </svg>
                  Continuar con Google
                </button>
              </form>
              </div>
            </div>
            </Fragment>
          )}
        </div>

        <!-- Back to Home -->
        <div class="mt-6 text-center">
          <a href="/" class="text-sm text-ink-muted hover:text-primary transition-colors">
            Volver al inicio
          </a>
        </div>
      </div>
    </main>

    <script define:vars={{ redirectTo }}>
      // DOM Elements
      const phoneInput = document.getElementById('phone-input')
      const phoneHint = document.getElementById('phone-hint')
      const btnContinuePhone = document.getElementById('btn-continue-phone')
      const phoneSection = document.getElementById('phone-section')
      const registrationForm = document.getElementById('registration-form')
      const btnCancelRegister = document.getElementById('btn-cancel-register')

      // Peruvian phone validation: 9 digits starting with 9
      function isValidPeruvianPhone(value) {
        const phoneRegex = /^9\d{8}$/
        return phoneRegex.test(value.trim())
      }

      // Phone input validation
      phoneInput?.addEventListener('input', e => {
        // Only allow numbers
        e.target.value = e.target.value.replace(/[^0-9]/g, '')

        const value = e.target.value
        const isValid = isValidPeruvianPhone(value)

        if (value.length > 0 && !isValid) {
          phoneHint.classList.remove('hidden')
        } else {
          phoneHint.classList.add('hidden')
        }

        btnContinuePhone.disabled = !isValid
      })

      // Continue with phone (guest mode)
      btnContinuePhone?.addEventListener('click', async () => {
        const phone = phoneInput.value.trim()
        if (!isValidPeruvianPhone(phone)) return

        btnContinuePhone.disabled = true
        btnContinuePhone.textContent = 'Ingresando...'

        try {
          const response = await fetch('/api/auth/phone-session', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
            },
            body: JSON.stringify({ phone, redirect: redirectTo }),
          })

          const data = await response.json()

          if (data.success) {
            window.location.href = data.redirect || redirectTo
          } else {
            phoneHint.textContent = data.error || 'Error al ingresar'
            phoneHint.classList.remove('hidden')
            phoneHint.classList.add('text-red-600')
          }
        } catch (error) {
          console.error('Phone session error:', error)
          phoneHint.textContent = 'Error al ingresar. Intenta nuevamente.'
          phoneHint.classList.remove('hidden')
          phoneHint.classList.add('text-red-600')
        } finally {
          btnContinuePhone.disabled = false
          btnContinuePhone.textContent = 'Continuar'
        }
      })

      // Cancel registration
      btnCancelRegister?.addEventListener('click', async () => {
        // Sign out if there's a pending session
        try {
          await fetch('/api/auth/signout', { method: 'POST' })
        } catch (e) {
          // Ignore errors
        }

        // Clear URL params and show phone section
        window.history.replaceState({}, '', '/ingresar')
        registrationForm.classList.add('hidden')
        phoneSection.classList.remove('hidden')
      })

      // Enter key support
      phoneInput?.addEventListener('keypress', e => {
        if (e.key === 'Enter' && !btnContinuePhone.disabled) {
          btnContinuePhone.click()
        }
      })
    </script>

    <style>
      html,
      body {
        margin: 0;
        width: 100%;
        min-height: 100%;
      }

      body {
        font-family:
          'Inter',
          system-ui,
          -apple-system,
          sans-serif;
      }
    </style>
  </body>
</html>
