---
import LayoutAdmin from '@/layouts/LayoutAdmin.astro'
import AdminPanel from '@/components/admin/AdminPanel.tsx'
import { isAdminOrStaff } from '@/utils/admin'

// All unauthorized access returns 404 - don't reveal admin page exists
// User must be authenticated AND have admin/staff role in database

if (!Astro.locals.user) {
  return Astro.redirect('/404')
}

const userId = Astro.locals.user.id
const hasAccess = await isAdminOrStaff(userId)

if (!hasAccess) {
  return Astro.redirect('/404')
}
---

<LayoutAdmin>
  <div class="max-w-6xl mx-auto px-4">
    <div class="mb-6">
      <h1 class="text-2xl font-bold text-heading">Bienvenido de nuevo</h1>
      <p class="text-sm text-ink-muted mt-1">Gestiona los productos y horarios de tu negocio</p>
    </div>

    <AdminPanel client:load />
  </div>
</LayoutAdmin>
